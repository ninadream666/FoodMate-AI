[run]
branch = True
source =
    backend/recommendation-service/app
    backend/ai-pricing-service/app
    backend/nutrivision-service/app
omit =
    */__pycache__/*
    */tests/*
    */migrations/*
    */node_modules/*
    # ===== 以下文件按工程惯例不计入单元测试覆盖率 =====
    # 1. ML 训练脚本（一次性脚本，非生产运行路径）
    */ml/train_*.py
    # 2. FastAPI 框架入口与配置（应由集成测试覆盖）
    */main.py
    */config.py
    # 3. Pydantic 数据模型声明（无逻辑可测）
    */models/schemas.py
    # 4. AI 服务的纯客户端封装（外部 API 调用层）
    */clients.py
    */deepseek_agent.py
    # 5. FastAPI 路由层（属于集成测试范畴，已由 tests/integration/ 与 tests/system/ 覆盖）
    */api/*.py
    # 6. 未启用的备用编排器与备用智能体（项目当前主链路使用 langgraph_orchestrator）
    */agents/parallel_orchestrator.py
    */agents/reasoning_agent.py
    # 7. 需要 PyTorch 模型权重的推理代码（无模型文件时强制 0%）
    */ml/foodcf_encoder.py
    */ml/ncf_model.py
parallel = False
relative_files = True

[report]
show_missing = True
skip_covered = False
precision = 2
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:

[html]
directory = tests/coverage/html
title = FoodMate-AI Python Coverage

[xml]
output = tests/coverage/coverage.xml

MAP_API_KEY=d93be6b2a94f35443978f16117ad1add

# 聚合数据节假日安排查询API配置
# 获取API密钥：https://www.juhe.cn/docs/api/id/1566
JUHE_CALENDAR_API_KEY=c0b5548aeef5ca8208fef30f417c1b3d

# 服务配置
DEBUG=false
LOG_LEVEL=INFO

# ============= AI 模型配置 =============
# 使用 DeepSeek
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=deepseek-chat
USE_AI_ORCHESTRATOR=true
USE_DEEPSEEK=true

# ============= 默认位置配置 =============
# 当前端未提供定位时使用的默认城市
# 建议改为您的业务覆盖区域的主要城市
DEFAULT_CITY=上海
DEFAULT_LATITUDE=31.2891
DEFAULT_LONGITUDE=121.2180
# 位置：上海市嘉定区同济大学

# ============= MCP 协议配置 =============
# 是否使用MCP协议模式（true=通过MCP协议与Server通信，false=直接调用API）
# MCP协议模式：mcp_client.py <-> MCP协议 <-> delivery_mcp_server.py <-> 真实API
# 直接调用模式：mcp_client.py <-> 真实API（跳过MCP协议，但仍使用MCP工具定义）
USE_MCP_PROTOCOL=true

# 推荐算法权重配置（可选，AI会动态调整）
WEATHER_WEIGHT=0.25
SEASONAL_WEIGHT=0.20
TIME_WEIGHT=0.20
TRAFFIC_WEIGHT=0.15
DISTANCE_WEIGHT=0.10
RATING_WEIGHT=0.10
# 服务配置
DEBUG=false
LOG_LEVEL=INFO

# ============= AI 模型配置 =============
# 方案1: 使用 OpenAI (需要充值)
OPENAI_MODEL=gpt-3.5-turbo
USE_AI_ORCHESTRATOR=true

# 方案2: 使用 DeepSeek (推荐，便宜)
# 注册地址: https://platform.deepseek.com/
# 设置为 true 启用 DeepSeek，需要同时设置 DEEPSEEK_API_KEY
USE_DEEPSEEK=true
DEEPSEEK_API_KEY=sk-fad86869fa544d138ca4ba64038af9e5

# ============= 默认位置配置 =============
# 当前端未提供定位时使用的默认城市
# 建议改为您的业务覆盖区域的主要城市
DEFAULT_CITY=上海
DEFAULT_LATITUDE=31.2891
DEFAULT_LONGITUDE=121.2180
# 位置：上海市嘉定区同济大学

# ============= MCP 协议配置 =============
# 是否使用MCP协议模式（true=通过MCP协议与Server通信，false=直接调用API）
# MCP协议模式：mcp_client.py <-> MCP协议 <-> delivery_mcp_server.py <-> 真实API
# 直接调用模式：mcp_client.py <-> 真实API（跳过MCP协议，但仍使用MCP工具定义）
USE_MCP_PROTOCOL=true

# 推荐算法权重配置（可选，AI会动态调整）
WEATHER_WEIGHT=0.25
SEASONAL_WEIGHT=0.20
TIME_WEIGHT=0.20
TRAFFIC_WEIGHT=0.15
DISTANCE_WEIGHT=0.10
RATING_WEIGHT=0.10
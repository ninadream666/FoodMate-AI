# 注册地址: https://dev.qweather.com/
QWEATHER_API_HOST=pj78kyqfxr.re.qweatherapi.com


# 认证方式选择：true=JWT认证，false=API Key认证（推荐JWT）
# 由于JWT配置复杂，暂时使用API Key认证
QWEATHER_USE_JWT=true

# JWT认证配置
# 1. 生成Ed25519密钥对：openssl genpkey -algorithm ED25519 -out ed25519-private.pem && openssl pkey -pubout -in ed25519-private.pem > ed25519-public.pem
# 2. 在和风天气控制台上传公钥并获取凭据ID和项目ID
QWEATHER_KEY_ID=C4WMK7YPBU
QWEATHER_PROJECT_ID=4FKRUTDRVJ
QWEATHER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEIAQZkeIFPs1oboGw0juR/+zC359zzigRw7avwfI3d1h0
-----END PRIVATE KEY-----"

# 传统API Key认证（备选方案）

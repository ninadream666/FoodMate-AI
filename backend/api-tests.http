###############################################################################
# 6. 订单服务 (Order) - 订单全流程
###############################################################################

### 6.1 创建订单
# @name createOrder
POST {{baseUrl}}:{{orderServicePort}}/orders
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "merchantId": 1,
  "items": [
    {
      "menuItemId": 1,
      "price": 15.50,
      "quantity": 1
    },
    {
      "menuItemId": 10,
      "price": 12.00,
      "quantity": 2
    }
  ]
}

@orderId = {{createOrder.response.body.id}}

### 6.2 查询我的订单列表
GET {{baseUrl}}:{{orderServicePort}}/orders/my-orders
Authorization: Bearer {{customerToken}}

### 6.3 查询指定用户的订单（内部接口）
GET {{baseUrl}}:{{orderServicePort}}/orders/user/1
Authorization: Bearer {{customerToken}}

### 6.4 获取订单详情（含价格信息）
GET {{baseUrl}}:{{orderServicePort}}/orders/3/detail
Authorization: Bearer {{customerToken}}

###############################################################################
# 7. 支付模拟 (Payment Simulation) - 模拟支付成功
###############################################################################

### 7.0 用户端支付接口（推荐使用）
# 这是用户在前端点击"支付"按钮后应该调用的接口
# 自动创建模拟支付信息并更新订单状态为PAID
# @name userPayOrder
POST {{baseUrl}}:{{orderServicePort}}/orders/11441/pay
Authorization: Bearer {{customerToken}}

### 7.1 模拟支付成功 - 完整版 (指定支付方式、交易号等)
# 内部接口，用于测试或第三方支付回调
# @name payOrder
POST {{baseUrl}}:{{orderServicePort}}/orders/internal/{{orderId}}/payment/confirm
Content-Type: application/json

{
  "paymentMethod": "WECHAT",
  "paymentTransactionId": "WX20231222123456789012345678",
  "paymentChannel": "APP",
  "paidAmount": 45.00,
  "remark": "模拟微信支付成功"
}

### 7.2 模拟支付成功 - 简化版 (自动生成交易号)
# 内部接口，快速测试用，自动生成模拟交易号
POST {{baseUrl}}:{{orderServicePort}}/orders/internal/{{orderId}}/payment/mock

### 7.3 模拟支付宝支付
POST {{baseUrl}}:{{orderServicePort}}/orders/internal/{{orderId}}/payment/confirm
Content-Type: application/json

{
  "paymentMethod": "ALIPAY",
  "paymentTransactionId": "ALI20231222987654321098765432",
  "paymentChannel": "MINI_PROGRAM",
  "paidAmount": 45.00,
  "remark": "模拟支付宝小程序支付成功"
}

### 7.4 查看支付后的订单详情 (确认支付信息已同步)
GET {{baseUrl}}:{{orderServicePort}}/orders/{{orderId}}/detail
Authorization: Bearer {{customerToken}}

###############################################################################
# 8. 售后与退款 (Refund & Cancellation) - 订单取消与退款
###############################################################################

### 8.1 用户取消订单（未接单状态 - 直接退款）
POST {{baseUrl}}:{{orderServicePort}}/orders/11438/cancel
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "cancelReason": "不想吃了"
}

### 8.2 用户取消订单（已接单状态 - 需要商家审批）
POST {{baseUrl}}:{{orderServicePort}}/orders/11451/cancel
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "cancelReason": "不想要了"
}

### 8.3 创建订单用于测试拒绝退款
POST {{baseUrl}}:{{orderServicePort}}/orders
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "merchantId": 1,
  "items": [
    {
      "menuItemId": 1,
      "price": 15.50,
      "quantity": 1
    }
  ]
}

### 8.4 申请取消订单（需要商家审批）
POST {{baseUrl}}:{{orderServicePort}}/orders/11216/cancel
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "cancelReason": "测试拒绝退款"
}

### 8.5 商家批准退款申请
PATCH {{baseUrl}}:{{merchantServicePort}}/merchants/1/orders/1/approve-cancel
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "approved": true
}

### 8.6 商家拒绝退款申请
PATCH {{baseUrl}}:{{merchantServicePort}}/merchants/1/orders/3/approve-cancel
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "approved": false,
  "rejectReason": "订单已出餐，无法取消"
}

### 8.7 查询商家的待审批退款订单列表
GET {{baseUrl}}:{{orderServicePort}}/orders/merchant/1/pending-refunds
Authorization: Bearer {{merchantToken}}

### 8.8 商家查看待审批退款列表
GET {{baseUrl}}:{{merchantServicePort}}/merchants/1/pending-refunds
Authorization: Bearer {{merchantToken}}

### 8.9 核销优惠券 (支付成功后调用)
POST {{baseUrl}}:{{marketingServicePort}}/coupons/1/use
Content-Type: application/json

{
  "couponId": 1,
  "orderId": 1001,
  "remark": "订单支付核销"
}

### 8.10 回滚优惠券 (订单取消后)
POST {{baseUrl}}:{{marketingServicePort}}/coupons/1/rollback
Content-Type: application/json

{
  "couponId": 1,
  "orderId": 1001,
  "reason": "用户取消订单"
}

###############################################################################
# 9. 订单内部接口 (Internal API) - 供其他微服务调用
###############################################################################

### 9.1 获取订单详情（内部接口）
GET {{baseUrl}}:{{orderServicePort}}/orders/internal/1

### 9.2 更新订单取消状态为已批准（内部接口）
POST {{baseUrl}}:{{orderServicePort}}/orders/internal/1/cancel-status/approve?refundAmount=43.00

### 9.3 更新订单取消状态为已拒绝（内部接口）
POST {{baseUrl}}:{{orderServicePort}}/orders/internal/2/cancel-status/reject

### 9.4 获取商家的待审批订单列表（内部接口）
GET {{baseUrl}}:{{orderServicePort}}/orders/internal/merchant/1/pending-refunds

### 9.5 记录用户取消订单并更新信用
POST {{baseUrl}}:{{userServicePort}}/users/1/cancellations/record?orderId=1&cancelReason=不想要了
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###############################################################################
# 10. 平台服务 (Platform) - 平台服务与结算管理
###############################################################################

### ⚠️  【重要】10.0 初始化商家强制订阅（结算单前置条件）
### 说明：订阅所有【强制服务】（isMandatory=true）
### 当前只有【平台技术服务费】设为强制，其余都是可选的
### 必须先执行此步骤，才能在创建订单后生成分成记录，进而生成结算单


# 使用实际的商家ID替代硬编码的1
POST {{baseUrl}}:{{platformServicePort}}/api/admin/platform-services/merchants/1/init-mandatory
Authorization: Bearer {{adminToken}}

# 先检查当前商家ID
# @name getCurrentMerchant
GET {{baseUrl}}:{{userServicePort}}/users/me
Authorization: Bearer {{merchantToken}}

### 10.0.1 调试：检查当前用户对应的商家信息
GET {{baseUrl}}:{{merchantServicePort}}/merchants/my
Authorization: Bearer {{merchantToken}}

### 10.0.2 调试：查看所有平台服务 
GET {{baseUrl}}:{{platformServicePort}}/api/merchant/platform-services
Authorization: Bearer {{merchantToken}}


### ==================== 商家端 - 平台服务 ====================


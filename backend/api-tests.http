# Food Delivery Platform - API 测试文件 (Complete)
# 包含所有微服务的完整业务流程
# 顺序：Auth(认证) -> Merchant(商家) -> User(用户) -> Marketing(营销) -> Recommendation(推荐) -> Order(订单) -> Payment(支付) -> Refund(售后) -> Platform(平台)

### 全局变量定义
@baseUrl = http://localhost
@aiAgentPort = 8000
@userServicePort = 8083
@orderServicePort = 8084
@merchantServicePort = 8081
@marketingServicePort = 8082
@profileServicePort = 8086
@recommendationServicePort = 8087
@platformServicePort = 8088
@aiPricingServicePort = 8089
@nutriVisionServicePort = 8090


###############################################################################
# 1. 认证初始化 (Authentication & Login)
###############################################################################

### 1.1 注册新用户（普通用户）

POST {{baseUrl}}:{{userServicePort}}/auth/register
Content-Type: application/json

{
  "username": "happy",
  "email": "happy@example.com",
  "password": "happy",
  "nickname": "happyday",
  "phone": "13900000001"
}

### 1.2 注册新商家用户
POST {{baseUrl}}:{{userServicePort}}/auth/register
Content-Type: application/json

{
  "username": "merchant_co",
  "email": "co@example.com",
  "password": "password123",
  "nickname": "c老板",
  "phone": "23900000091",
  "role": "merchant"
}

### 1.3 注册新管理员用户
POST {{baseUrl}}:{{userServicePort}}/auth/register
Content-Type: application/json

{
  "username": "newadmin",
  "email": "admin@example.com",
  "password": "password123",
  "phone": "13900000091",
  "role": "admin"
}

### 1.4 用户登录（普通用户）
# @name loginCustomer
POST {{baseUrl}}:{{userServicePort}}/auth/login
Content-Type: application/json

{
  "username": "happy",
  "password": "happy",
  "role": "customer"
}

### 1.5 商家登录 (使用有商家数据的bob用户)
# @name loginMerchant
POST {{baseUrl}}:{{userServicePort}}/auth/login
Content-Type: application/json

{
  "username": "bob",
  "password": "password123",
  "role": "merchant"
}

### 1.6 管理员登录
# @name loginAdmin
POST {{baseUrl}}:{{userServicePort}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password123",
  "role": "admin"
}

# 以下token会在执行1.4-1.6登录后自动更新
@customerToken = {{loginCustomer.response.body.token}}
@merchantToken = {{loginMerchant.response.body.token}} 
@adminToken = {{loginAdmin.response.body.token}}
@currentCustomerId = {{loginCustomer.response.body.id}}

###############################################################################
# 2. 商家服务 (Merchant) - 餐厅与菜单管理
###############################################################################

### 2.1 商家创建餐厅
# @name createShop
POST {{baseUrl}}:{{merchantServicePort}}/merchants
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "全流程测试餐厅",
  "address": "测试大道888号"
}

### 变量：自动获取餐厅ID
@merchantId = {{createShop.response.body.id}}

### 2.1.1 更新商家自动审批设置 (Update Auto-Approval)
PATCH {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/auto-approval?enable=true&threshold=0.03
Authorization: Bearer {{merchantToken}}

### 2.1.2 关闭商家自动审批 (Disable Auto-Approval)
PATCH {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/auto-approval?enable=false
Authorization: Bearer {{merchantToken}}

### 2.2 查看我的餐厅信息
GET {{baseUrl}}:{{merchantServicePort}}/merchants/my
Authorization: Bearer {{merchantToken}}

### 2.3 添加菜品 1 (主食)
# @name addDish1
POST {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/menu-items
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "招牌牛肉面",
  "price": 28.00,
  "description": "大块牛肉，劲道面条",
  "category": "主食",
  "imageUrl": "http://example.com/beef.jpg"
}

### 2.4 添加菜品 2 (小吃)
# @name addDish2
POST {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/menu-items
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "name": "酥脆炸鸡排",
  "price": 15.00,
  "description": "外酥里嫩，黄金色泽",
  "category": "小吃",
  "imageUrl": "http://example.com/chicken.jpg"
}

### 变量：自动获取菜品ID
@menuItem1 = {{addDish1.response.body.id}}
@menuItem2 = {{addDish2.response.body.id}}

### 2.5 修改菜品信息
PUT {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/menu-items/{{menuItem1}}
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "price": 30.00,
  "description": "大块牛肉，价格微调"
}

### 2.6 商家查看自己的菜单 (含下架商品)
GET {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/menu-items
Authorization: Bearer {{merchantToken}}

### 2.7 顾客/公开查看商家菜单 (仅上架商品)
GET {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/menu-items/public

### 2.8 商家查看销售数据 (TODO)
GET {{baseUrl}}:{{merchantServicePort}}/merchants/{{merchantId}}/sales
Authorization: Bearer {{merchantToken}}

###############################################################################
# 3. 用户服务 (User & Profile) - 用户信息与画像
###############################################################################

### 3.1 获取当前用户信息
GET {{baseUrl}}:{{userServicePort}}/users/me
Authorization: Bearer {{customerToken}}

### 3.2 更新用户信息
PUT {{baseUrl}}:{{userServicePort}}/users/me
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "nickname": "美食家小王",
  "avatarUrl": "https://example.com/new_avatar.jpg",
  "phone": "13911112222"
}

### 3.3 获取用户信用信息
GET {{baseUrl}}:{{userServicePort}}/users/1/credit
Authorization: Bearer {{customerToken}}

### 3.4 尝试升级信用等级
POST {{baseUrl}}:{{userServicePort}}/users/1/credit/upgrade
Authorization: Bearer {{customerToken}}

### 3.5 获取用户画像/资料
GET {{baseUrl}}:{{profileServicePort}}/profile
Authorization: Bearer {{customerToken}}

### 3.6 完善用户画像 (用于推荐系统冷启动)
POST {{baseUrl}}:{{profileServicePort}}/profile
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "username": "user_full_test",
  "bio": "无辣不欢的美食家",
  "preferences": {
    "favoriteFood": "面食",
    "spicyLevel": "high"
  },
  "favoriteCategories": ["面食", "炸物"]
}

###############################################################################
# 4. 营销服务 (Marketing) - 优惠券管理
###############################################################################

### 4.1 创建优惠券模板 (运营)
# @name createCouponTemplate
POST {{baseUrl}}:{{marketingServicePort}}/coupons/templates
Content-Type: application/json

{
  "name": "新用户首单立减",
  "type": "DISCOUNT",
  "discountValue": 10,
  "maxDiscount": 50,
  "minOrderAmount": 30,
  "totalQuantity": 1000,
  "enabled": true,
  "stackable": false,
  "validFrom": "2025-01-01T00:00:00",
  "validUntil": "2025-12-31T23:59:59",
  "exclusiveIds": "[]",
  "applicableMerchantIds": "[]"
}

@templateId = {{createCouponTemplate.response.body.data.id}}

### 4.2 更新优惠券模板
PUT {{baseUrl}}:{{marketingServicePort}}/coupons/templates/1
Content-Type: application/json

{
  "id": 1,
  "name": "新用户首单立减(已更新)",
  "enabled": true,
  "addQuantity": 100
}

### 4.3 发放优惠券给用户
POST {{baseUrl}}:{{marketingServicePort}}/coupons/issue
Content-Type: application/json

{
  "couponTemplateId": 1,
  "userId": 5
}

### 4.4 管理员发放优惠券
POST {{baseUrl}}:{{marketingServicePort}}/coupons/admin/issue
Content-Type: application/json

{
  "couponTemplateId": 1,
  "userId": 5,
  "remark": "管理员补发"
}

### 4.5 管理员批量发放优惠券
POST {{baseUrl}}:{{marketingServicePort}}/coupons/admin/issue-batch
Content-Type: application/json

{
  "couponTemplateId": 1,
  "userIds": [1, 2, 3],
  "remark": "节日活动批量发放"
}

### 4.6 用户主动领取优惠券
POST {{baseUrl}}:{{marketingServicePort}}/coupons/issue
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "couponTemplateId": {{templateId}}
}

### 4.7 获取用户可用优惠券
GET {{baseUrl}}:{{marketingServicePort}}/coupons/user/1/available

### 4.7.1 获取用户可用优惠券（按订单金额过滤）
GET {{baseUrl}}:{{marketingServicePort}}/coupons/user/1/available?orderAmount=50.00

### 4.7.2 获取用户可用优惠券（订单金额不满足条件）
GET {{baseUrl}}:{{marketingServicePort}}/coupons/user/1/available?orderAmount=20.00

### 4.8 获取用户所有优惠券
GET {{baseUrl}}:{{marketingServicePort}}/coupons/user/1/all

### 4.9 获取优惠券详情
GET {{baseUrl}}:{{marketingServicePort}}/coupons/1

### 4.9.1 检查优惠券使用条件（金额满足）
GET {{baseUrl}}:{{marketingServicePort}}/coupons/1/check-amount?orderAmount=50.00

### 4.9.2 检查优惠券使用条件（金额不满足）
GET {{baseUrl}}:{{marketingServicePort}}/coupons/1/check-amount?orderAmount=20.00

### 4.10 计算最优优惠券组合
POST {{baseUrl}}:{{marketingServicePort}}/coupons/calculate-best
Content-Type: application/json

{
  "userId": 1,
  "merchantId": 1,
  "orderTotal": 100.00,
  "items": [
    {
      "itemId": 101,
      "price": 50.00,
      "quantity": 1,
      "merchantId": 1
    },
    {
      "itemId": 102,
      "price": 50.00,
      "quantity": 1,
      "merchantId": 1
    }
  ]
}

### 4.11 验证优惠券组合
POST {{baseUrl}}:{{marketingServicePort}}/coupons/validate-combination
Content-Type: application/json

[1]

### 4.12 营销服务健康检查
GET {{baseUrl}}:{{marketingServicePort}}/coupons/health

###############################################################################
# 4.2. 智能发放管理 (Smart Issuance) - 自动化发放系统
###############################################################################

### 4.2.1 智能发放服务健康检查
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/health

### 4.2.2 创建新用户注册自动发放规则
# @name createNewUserRule
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ruleName": "新用户首单优惠券",
  "description": "用户注册后7天内自动发放首单优惠券",
  "triggerType": "NEW_USER",
  "couponTemplateId": 1,
  "enabled": true,
  "conditionJson": "{\"registrationDays\": 7, \"registrationSource\": \"mobile_app\"}",
  "frequency": "ONCE",
  "priority": 10,
  "effectiveFrom": "2025-01-01T00:00:00",
  "effectiveUntil": "2025-12-31T23:59:59",
  "totalIssueLimit": 10000
}

### 4.2.3 创建高信用用户发放规则
# @name createHighCreditRule
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ruleName": "高信用用户专享优惠",
  "description": "信用等级达到5级及以上用户自动发放专享优惠券",
  "triggerType": "CREDIT_UPGRADE",
  "couponTemplateId": 1,
  "enabled": true,
  "conditionJson": "{\"minCreditLevel\": 5, \"maxCreditLevel\": 10}",
  "frequency": "ONCE",
  "priority": 20,
  "effectiveFrom": "2025-01-01T00:00:00",
  "effectiveUntil": "2025-12-31T23:59:59",
  "totalIssueLimit": 5000
}

### 4.2.4 创建订单里程碑发放规则
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ruleName": "订单里程碑奖励",
  "description": "用户累计订单满10单且消费满500元自动发放奖励优惠券",
  "triggerType": "ORDER_MILESTONE",
  "couponTemplateId": 1,
  "enabled": true,
  "conditionJson": "{\"minOrderCount\": 10, \"minTotalAmount\": 500.0}",
  "frequency": "ONCE",
  "priority": 30,
  "totalIssueLimit": 1000
}

### 4.2.5 创建生日用户发放规则
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ruleName": "生日专享优惠",
  "description": "用户生日当天前后3天内自动发放生日专享优惠券",
  "triggerType": "BIRTHDAY",
  "couponTemplateId": 1,
  "enabled": true,
  "conditionJson": "{\"birthdayDaysRange\": 3}",
  "frequency": "ONCE",
  "priority": 15,
  "totalIssueLimit": 2000
}

@newUserRuleId = {{createNewUserRule.response.body.data.id}}
@highCreditRuleId = {{createHighCreditRule.response.body.data.id}}

### 4.2.6 查询所有智能发放规则
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules?page=0&size=10
Authorization: Bearer {{adminToken}}

### 4.2.7 查询启用的规则
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules?enabled=true&page=0&size=10
Authorization: Bearer {{adminToken}}

### 4.2.8 获取规则详情
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules/{{newUserRuleId}}
Authorization: Bearer {{adminToken}}

### 4.2.9 更新自动发放规则
PUT {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules/{{newUserRuleId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ruleName": "新用户首单优惠券(已更新)",
  "description": "用户注册后3天内自动发放首单优惠券",
  "triggerType": "NEW_USER",
  "couponTemplateId": 1,
  "enabled": true,
  "conditionJson": "{\"registrationDays\": 3}",
  "frequency": "ONCE",
  "priority": 5,
  "totalIssueLimit": 15000
}

### 4.2.10 禁用规则
PATCH {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules/{{newUserRuleId}}/status?enabled=false
Authorization: Bearer {{adminToken}}

### 4.2.11 重新启用规则
PATCH {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules/{{newUserRuleId}}/status?enabled=true
Authorization: Bearer {{adminToken}}

### 4.2.12 手动触发新用户发放（测试接口）
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/new-user/{{currentCustomerId}}
Authorization: Bearer {{adminToken}}

### 4.2.13 手动触发高信用用户发放（测试接口）
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/high-credit/{{currentCustomerId}}?creditLevel=8
Authorization: Bearer {{adminToken}}

### 4.2.14 用户事件触发（内部接口）- 新用户注册
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/trigger
Content-Type: application/json

{
  "userId": {{currentCustomerId}},
  "eventType": "NEW_USER",
  "eventData": "{\"registeredAt\": \"2025-01-03T10:00:00\", \"registrationSource\": \"mobile_app\"}",
  "eventTime": "2025-01-03T10:00:00",
  "sourceService": "user-service"
}

### 4.2.15 用户事件触发（内部接口）- 信用升级
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/trigger
Content-Type: application/json

{
  "userId": {{currentCustomerId}},
  "eventType": "CREDIT_UPGRADE",
  "eventData": "{\"oldLevel\": 3, \"newLevel\": 6, \"upgradeReason\": \"good_payment_history\"}",
  "eventTime": "2025-01-03T10:00:00",
  "sourceService": "user-service"
}

### 4.2.16 用户事件触发（内部接口）- 订单里程碑
POST {{baseUrl}}:{{marketingServicePort}}/coupons/smart/trigger
Content-Type: application/json

{
  "userId": {{currentCustomerId}},
  "eventType": "ORDER_MILESTONE",
  "eventData": "{\"orderCount\": 12, \"totalAmount\": 680.5, \"milestoneType\": \"order_count\"}",
  "eventTime": "2025-01-03T10:00:00",
  "sourceService": "order-service"
}

### 4.2.17 获取智能发放统计信息
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/stats
Authorization: Bearer {{adminToken}}

### 4.2.18 获取指定规则的统计信息（最近7天）
GET {{baseUrl}}:{{marketingServicePort}}/coupons/smart/stats?ruleId={{newUserRuleId}}&fromTime=2025-01-01T00:00:00
Authorization: Bearer {{adminToken}}

### 4.2.19 软删除规则
DELETE {{baseUrl}}:{{marketingServicePort}}/coupons/smart/rules/{{highCreditRuleId}}
Authorization: Bearer {{adminToken}}

###############################################################################
# 5. 推荐服务 (Recommendation & AI) - 智能推荐系统
# 基于LangGraph多智能体协作：ContextAgent → ProfilerAgent → DecisionAgent
###############################################################################

### 5.1 推荐服务健康检查
GET {{baseUrl}}:{{recommendationServicePort}}/health

### 5.2 V2 多智能体推荐（主要功能）
POST {{baseUrl}}:{{recommendationServicePort}}/api/v2/agents/recommend
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "user_id": "5",
  "location": {
    "address": "北京市朝阳区建国门外大街",
    "latitude": 31.2891,
    "longitude": 121.2180
  },
  "preferences": {
    "cuisine_types": ["川菜", "火锅"],
    "spice_level": "中辣",
    "price_sensitivity": "medium"
  },
  "query": "想吃辣的川菜或火锅",
  "max_results": 10
}

### 5.3 V2 首页推荐（替代V1）
# 上海同济大学嘉定校区坐标
POST {{baseUrl}}:{{recommendationServicePort}}/api/v2/agents/recommend
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "user_id": "5",
  "location": {
    "address": "上海市嘉定区同济大学嘉定校区",
    "latitude": 31.2847,
    "longitude": 121.2180
  },
  "query": "为我推荐附近的美食",
  "max_results": 10
}

### 5.4 MCP服务健康检查
GET {{baseUrl}}:{{recommendationServicePort}}/api/v2/mcp/status


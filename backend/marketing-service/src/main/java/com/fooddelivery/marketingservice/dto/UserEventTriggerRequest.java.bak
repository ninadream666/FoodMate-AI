package com.fooddelivery.marketingservice.dto;

import com.fooddelivery.marketingservice.entity.AutoIssuanceRule;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Data;
import lombok.NoArgsConstructor;

/**
 * 用户事件触发DTO
 * 用于接收来自其他服务的事件通知
 */
@Data
@Builder
@NoArgsConstructor
@AllArgsConstructor
public class UserEventTriggerRequest {

    /**
     * 用户ID
     */
    private Long userId;

    /**
     * 事件类型
     */
    private AutoIssuanceRule.TriggerType eventType;

    /**
     * 事件详细数据（JSON格式）
     * 例如：
     * NEW_USER: {"registeredAt": "2023-12-01T10:00:00", "registrationSource":
     * "mobile_app"}
     * CREDIT_UPGRADE: {"oldLevel": 3, "newLevel": 5, "upgradeReason":
     * "good_payment_history"}
     * ORDER_MILESTONE: {"orderCount": 10, "totalAmount": 1000.0}
     */
    private String eventData;

    /**
     * 事件发生时间
     */
    private java.time.LocalDateTime eventTime;

    /**
     * 事件来源服务
     */
    private String sourceService;
}
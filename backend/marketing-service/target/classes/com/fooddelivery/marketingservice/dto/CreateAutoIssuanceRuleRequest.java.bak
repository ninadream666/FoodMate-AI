package com.fooddelivery.marketingservice.dto;

import com.fooddelivery.marketingservice.entity.AutoIssuanceRule;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Data;
import lombok.NoArgsConstructor;

import jakarta.validation.constraints.NotNull;
import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.Min;
import java.time.LocalDateTime;

/**
 * 创建自动发放规则请求DTO
 */
@Data
@Builder
@NoArgsConstructor
@AllArgsConstructor
public class CreateAutoIssuanceRuleRequest {

    @NotBlank(message = "规则名称不能为空")
    private String ruleName;

    private String description;

    @NotNull(message = "触发类型不能为空")
    private AutoIssuanceRule.TriggerType triggerType;

    @NotNull(message = "优惠券模板ID不能为空")
    @Min(value = 1, message = "优惠券模板ID必须大于0")
    private Long couponTemplateId;

    @Builder.Default
    private Boolean enabled = true;

    /**
     * 规则条件JSON字符串
     * 示例：
     * 新用户：{"registrationDays": 7} 表示注册7天内的新用户
     * 信用升级：{"minCreditLevel": 5, "maxCreditLevel": 10} 表示信用等级5-10级的用户
     * 生日：{"birthdayDaysRange": 3} 表示生日前后3天
     */
    private String conditionJson;

    @Builder.Default
    private AutoIssuanceRule.IssuanceFrequency frequency = AutoIssuanceRule.IssuanceFrequency.ONCE;

    @Builder.Default
    @Min(value = 1, message = "优先级必须大于0")
    private Integer priority = 100;

    private LocalDateTime effectiveFrom;

    private LocalDateTime effectiveUntil;

    @Min(value = 1, message = "发放限制必须大于0")
    private Integer totalIssueLimit;
}
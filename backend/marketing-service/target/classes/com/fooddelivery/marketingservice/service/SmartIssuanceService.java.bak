package com.fooddelivery.marketingservice.service;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fooddelivery.marketingservice.dto.*;
import com.fooddelivery.marketingservice.entity.*;
import com.fooddelivery.marketingservice.repository.*;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.*;
import java.util.stream.Collectors;

/**
 * 智能自动发放服务
 * 负责管理优惠券的自动发放规则和执行逻辑
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class SmartIssuanceService {

    private final AutoIssuanceRuleRepository ruleRepository;
    private final AutoIssuanceHistoryRepository historyRepository;
    private final CouponTemplateRepository couponTemplateRepository;
    private final CouponIssueService couponIssueService;
    private final ObjectMapper objectMapper;

    /**
     * 创建自动发放规则
     */
    @Transactional
    public AutoIssuanceRuleDTO createRule(CreateAutoIssuanceRuleRequest request, Long createdBy) {
        // 验证优惠券模板是否存在
        CouponTemplate template = couponTemplateRepository.findById(request.getCouponTemplateId())
                .orElseThrow(() -> new IllegalArgumentException("优惠券模板不存在: " + request.getCouponTemplateId()));

        AutoIssuanceRule rule = AutoIssuanceRule.builder()
                .ruleName(request.getRuleName())
                .description(request.getDescription())
                .triggerType(request.getTriggerType())
                .couponTemplateId(request.getCouponTemplateId())
                .enabled(request.getEnabled())
                .conditionJson(request.getConditionJson())
                .frequency(request.getFrequency())
                .priority(request.getPriority())
                .effectiveFrom(request.getEffectiveFrom())
                .effectiveUntil(request.getEffectiveUntil())
                .totalIssueLimit(request.getTotalIssueLimit())
                .createdBy(createdBy)
                .build();

        AutoIssuanceRule savedRule = ruleRepository.save(rule);
        log.info("创建自动发放规则成功，ID: {}, 规则名称: {}", savedRule.getId(), savedRule.getRuleName());

        return convertToDTO(savedRule, template);
    }

    /**
     * 更新自动发放规则
     */
    @Transactional
    public AutoIssuanceRuleDTO updateRule(Long ruleId, CreateAutoIssuanceRuleRequest request) {
        AutoIssuanceRule rule = ruleRepository.findById(ruleId)
                .orElseThrow(() -> new IllegalArgumentException("规则不存在: " + ruleId));

        // 验证优惠券模板是否存在
        CouponTemplate template = couponTemplateRepository.findById(request.getCouponTemplateId())
                .orElseThrow(() -> new IllegalArgumentException("优惠券模板不存在: " + request.getCouponTemplateId()));

        // 更新规则属性
        rule.setRuleName(request.getRuleName());
        rule.setDescription(request.getDescription());
        rule.setTriggerType(request.getTriggerType());
        rule.setCouponTemplateId(request.getCouponTemplateId());
        rule.setEnabled(request.getEnabled());
        rule.setConditionJson(request.getConditionJson());
        rule.setFrequency(request.getFrequency());
        rule.setPriority(request.getPriority());
        rule.setEffectiveFrom(request.getEffectiveFrom());
        rule.setEffectiveUntil(request.getEffectiveUntil());
        rule.setTotalIssueLimit(request.getTotalIssueLimit());

        AutoIssuanceRule savedRule = ruleRepository.save(rule);
        log.info("更新自动发放规则成功，ID: {}", savedRule.getId());

        return convertToDTO(savedRule, template);
    }

    /**
     * 启用/禁用规则
     */
    @Transactional
    public void toggleRuleStatus(Long ruleId, boolean enabled) {
        AutoIssuanceRule rule = ruleRepository.findById(ruleId)
                .orElseThrow(() -> new IllegalArgumentException("规则不存在: " + ruleId));

        rule.setEnabled(enabled);
        ruleRepository.save(rule);
        log.info("规则状态更新，ID: {}, 启用: {}", ruleId, enabled);
    }

    /**
     * 删除规则
     */
    @Transactional
    public void deleteRule(Long ruleId) {
        AutoIssuanceRule rule = ruleRepository.findById(ruleId)
                .orElseThrow(() -> new IllegalArgumentException("规则不存在: " + ruleId));

        // 软删除：禁用规则而不是物理删除，保持历史数据完整性
        rule.setEnabled(false);
        ruleRepository.save(rule);
        log.info("规则已禁用（软删除），ID: {}", ruleId);
    }

    /**
     * 分页查询规则列表
     */
    public Page<AutoIssuanceRuleDTO> getRules(Boolean enabled, int page, int size) {
        Pageable pageable = PageRequest.of(page, size, Sort.by("priority", "id"));
        Page<AutoIssuanceRule> rulePage;

        if (enabled != null) {
            rulePage = ruleRepository.findByEnabledOrderByPriorityAscIdAsc(enabled, pageable);
        } else {
            rulePage = ruleRepository.findAll(pageable);
        }

        return rulePage.map(rule -> {
            CouponTemplate template = couponTemplateRepository.findById(rule.getCouponTemplateId()).orElse(null);
            return convertToDTO(rule, template);
        });
    }

    /**
     * 获取规则详情
     */
    public AutoIssuanceRuleDTO getRuleById(Long ruleId) {
        AutoIssuanceRule rule = ruleRepository.findById(ruleId)
                .orElseThrow(() -> new IllegalArgumentException("规则不存在: " + ruleId));

        CouponTemplate template = couponTemplateRepository.findById(rule.getCouponTemplateId()).orElse(null);
        return convertToDTO(rule, template);
    }

    /**
     * 处理用户事件触发
     * 这是智能发放的核心方法
     */
    @Transactional
    public List<UserCouponDTO> processUserEventTrigger(UserEventTriggerRequest eventRequest) {
        long startTime = System.currentTimeMillis();
        List<UserCouponDTO> issuedCoupons = new ArrayList<>();

        try {
            log.info("处理用户事件触发，用户ID: {}, 事件类型: {}",
                    eventRequest.getUserId(), eventRequest.getEventType());

            // 查找匹配的规则
            List<AutoIssuanceRule> matchingRules = findMatchingRules(eventRequest);

            if (matchingRules.isEmpty()) {
                log.debug("未找到匹配的自动发放规则，用户ID: {}, 事件类型: {}",
                        eventRequest.getUserId(), eventRequest.getEventType());
                return issuedCoupons;
            }

            // 按优先级处理每个匹配的规则
            for (AutoIssuanceRule rule : matchingRules) {
                try {
                    UserCouponDTO issuedCoupon = processRuleForUser(rule, eventRequest, startTime);
                    if (issuedCoupon != null) {
                        issuedCoupons.add(issuedCoupon);
                    }
                } catch (Exception e) {
                    log.error("处理规则失败，规则ID: {}, 用户ID: {}, 错误: {}",
                            rule.getId(), eventRequest.getUserId(), e.getMessage(), e);

                    // 记录失败历史
                    recordFailureHistory(rule, eventRequest, e.getMessage(), startTime);
                }
            }

            log.info("用户事件处理完成，用户ID: {}, 发放优惠券数量: {}",
                    eventRequest.getUserId(), issuedCoupons.size());

        } catch (Exception e) {
            log.error("处理用户事件触发失败，用户ID: {}, 错误: {}",
                    eventRequest.getUserId(), e.getMessage(), e);
            throw e;
        }

        return issuedCoupons;
    }

    /**
     * 查找匹配的规则
     */
    private List<AutoIssuanceRule> findMatchingRules(UserEventTriggerRequest eventRequest) {
        LocalDateTime now = LocalDateTime.now();
        List<AutoIssuanceRule> candidateRules = ruleRepository
                .findValidRulesByTriggerTypeOrderByPriority(eventRequest.getEventType(), now);

        return candidateRules.stream()
                .filter(rule -> evaluateRuleCondition(rule, eventRequest))
                .filter(rule -> !isUserAlreadyReceived(rule, eventRequest))
                .collect(Collectors.toList());
    }

    /**
     * 评估规则条件是否满足
     */
    private boolean evaluateRuleCondition(AutoIssuanceRule rule, UserEventTriggerRequest eventRequest) {
        if (rule.getConditionJson() == null || rule.getConditionJson().isEmpty()) {
            return true; // 无条件限制，直接匹配
        }

        try {
            Map<String, Object> condition = objectMapper.readValue(rule.getConditionJson(), Map.class);
            Map<String, Object> eventData = objectMapper.readValue(eventRequest.getEventData(), Map.class);

            return evaluateConditionLogic(rule.getTriggerType(), condition, eventData, eventRequest);
        } catch (Exception e) {
            log.error("解析规则条件失败，规则ID: {}, 错误: {}", rule.getId(), e.getMessage());
            return false;
        }
    }

    /**
     * 具体的条件逻辑评估
     */
    private boolean evaluateConditionLogic(AutoIssuanceRule.TriggerType triggerType,
            Map<String, Object> condition,
            Map<String, Object> eventData,
            UserEventTriggerRequest eventRequest) {
        switch (triggerType) {
            case NEW_USER:
                return evaluateNewUserCondition(condition, eventData, eventRequest);
            case CREDIT_UPGRADE:
                return evaluateCreditUpgradeCondition(condition, eventData);
            case ORDER_MILESTONE:
                return evaluateOrderMilestoneCondition(condition, eventData);
            case BIRTHDAY:
                return evaluateBirthdayCondition(condition, eventData, eventRequest);
            default:
                return true;
        }
    }

    /**
     * 评估新用户条件
     */
    private boolean evaluateNewUserCondition(Map<String, Object> condition,
            Map<String, Object> eventData,
            UserEventTriggerRequest eventRequest) {
        // 检查注册天数限制
        if (condition.containsKey("registrationDays")) {
            Integer maxDays = (Integer) condition.get("registrationDays");
            LocalDateTime registeredAt = eventRequest.getEventTime();
            if (registeredAt != null) {
                long daysSinceRegistration = ChronoUnit.DAYS.between(registeredAt, LocalDateTime.now());
                if (daysSinceRegistration > maxDays) {
                    return false;
                }
            }
        }

        // 检查注册来源限制
        if (condition.containsKey("registrationSource")) {
            String requiredSource = (String) condition.get("registrationSource");
            String actualSource = (String) eventData.get("registrationSource");
            if (!Objects.equals(requiredSource, actualSource)) {
                return false;
            }
        }

        return true;
    }

    /**
     * 评估信用升级条件
     */
    private boolean evaluateCreditUpgradeCondition(Map<String, Object> condition, Map<String, Object> eventData) {
        if (condition.containsKey("minCreditLevel")) {
            Integer minLevel = (Integer) condition.get("minCreditLevel");
            Integer newLevel = (Integer) eventData.get("newLevel");
            if (newLevel == null || newLevel < minLevel) {
                return false;
            }
        }

        if (condition.containsKey("maxCreditLevel")) {
            Integer maxLevel = (Integer) condition.get("maxCreditLevel");
            Integer newLevel = (Integer) eventData.get("newLevel");
            if (newLevel == null || newLevel > maxLevel) {
                return false;
            }
        }

        return true;
    }

    /**
     * 评估订单里程碑条件
     */
    private boolean evaluateOrderMilestoneCondition(Map<String, Object> condition, Map<String, Object> eventData) {
        if (condition.containsKey("minOrderCount")) {
            Integer minCount = (Integer) condition.get("minOrderCount");
            Integer orderCount = (Integer) eventData.get("orderCount");
            if (orderCount == null || orderCount < minCount) {
                return false;
            }
        }

        if (condition.containsKey("minTotalAmount")) {
            Double minAmount = (Double) condition.get("minTotalAmount");
            Double totalAmount = (Double) eventData.get("totalAmount");
            if (totalAmount == null || totalAmount < minAmount) {
                return false;
            }
        }

        return true;
    }

    /**
     * 评估生日条件
     */
    private boolean evaluateBirthdayCondition(Map<String, Object> condition,
            Map<String, Object> eventData,
            UserEventTriggerRequest eventRequest) {
        // 默认生日前后3天都有效
        Integer daysRange = (Integer) condition.getOrDefault("birthdayDaysRange", 3);

        // 这里需要从eventData中获取用户生日信息进行判断
        // 具体实现取决于事件数据的结构
        return true; // 简化处理，实际需要根据生日日期计算
    }

    /**
     * 检查用户是否已经收到过该规则的优惠券
     */
    private boolean isUserAlreadyReceived(AutoIssuanceRule rule, UserEventTriggerRequest eventRequest) {
        LocalDateTime checkTime;

        switch (rule.getFrequency()) {
            case ONCE:
                checkTime = LocalDateTime.of(1970, 1, 1, 0, 0); // 检查所有历史
                break;
            case DAILY:
                checkTime = LocalDateTime.now().truncatedTo(ChronoUnit.DAYS);
                break;
            case WEEKLY:
                checkTime = LocalDateTime.now().minusDays(7);
                break;
            case MONTHLY:
                checkTime = LocalDateTime.now().minusDays(30);
                break;
            default:
                checkTime = LocalDateTime.of(1970, 1, 1, 0, 0);
        }

        return historyRepository.existsByUserIdAndRuleIdAndSuccessfulTrueAndIssuedAtAfter(
                eventRequest.getUserId(), rule.getId(), checkTime);
    }

    /**
     * 为用户处理单个规则
     */
    private UserCouponDTO processRuleForUser(AutoIssuanceRule rule,
            UserEventTriggerRequest eventRequest,
            long startTime) {
        try {
            // 发放优惠券
            IssueCouponRequest issueRequest = IssueCouponRequest.builder()
                    .couponTemplateId(rule.getCouponTemplateId())
                    .userId(eventRequest.getUserId())
                    .build();

            UserCouponDTO issuedCoupon = couponIssueService.issueCoupon(issueRequest);

            // 更新规则发放计数
            rule.incrementIssuedCount();
            ruleRepository.save(rule);

            // 记录成功历史
            recordSuccessHistory(rule, eventRequest, issuedCoupon.getId(), startTime);

            log.info("自动发放成功，规则ID: {}, 用户ID: {}, 优惠券ID: {}",
                    rule.getId(), eventRequest.getUserId(), issuedCoupon.getId());

            return issuedCoupon;
        } catch (Exception e) {
            log.error("自动发放失败，规则ID: {}, 用户ID: {}, 错误: {}",
                    rule.getId(), eventRequest.getUserId(), e.getMessage());
            throw e;
        }
    }

    /**
     * 记录成功历史
     */
    private void recordSuccessHistory(AutoIssuanceRule rule, UserEventTriggerRequest eventRequest,
            Long userCouponId, long startTime) {
        long processingTime = System.currentTimeMillis() - startTime;
        AutoIssuanceHistory history = AutoIssuanceHistory.createSuccessRecord(
                eventRequest.getUserId(),
                rule.getId(),
                userCouponId,
                eventRequest.getEventType(),
                eventRequest.getEventData(),
                processingTime);
        historyRepository.save(history);
    }

    /**
     * 记录失败历史
     */
    private void recordFailureHistory(AutoIssuanceRule rule, UserEventTriggerRequest eventRequest,
            String failureReason, long startTime) {
        long processingTime = System.currentTimeMillis() - startTime;
        AutoIssuanceHistory history = AutoIssuanceHistory.createFailureRecord(
                eventRequest.getUserId(),
                rule.getId(),
                eventRequest.getEventType(),
                eventRequest.getEventData(),
                failureReason,
                processingTime);
        historyRepository.save(history);
    }

    /**
     * 转换为DTO
     */
    private AutoIssuanceRuleDTO convertToDTO(AutoIssuanceRule rule, CouponTemplate template) {
        return AutoIssuanceRuleDTO.builder()
                .id(rule.getId())
                .ruleName(rule.getRuleName())
                .description(rule.getDescription())
                .triggerType(rule.getTriggerType())
                .couponTemplateId(rule.getCouponTemplateId())
                .couponTemplateName(template != null ? template.getName() : null)
                .enabled(rule.getEnabled())
                .conditionJson(rule.getConditionJson())
                .frequency(rule.getFrequency())
                .priority(rule.getPriority())
                .createdAt(rule.getCreatedAt())
                .updatedAt(rule.getUpdatedAt())
                .effectiveFrom(rule.getEffectiveFrom())
                .effectiveUntil(rule.getEffectiveUntil())
                .totalIssueLimit(rule.getTotalIssueLimit())
                .issuedCount(rule.getIssuedCount())
                .createdBy(rule.getCreatedBy())
                .build();
    }

    /**
     * 获取发放统计信息
     */
    public Map<String, Object> getIssuanceStats(Long ruleId, LocalDateTime fromTime) {
        if (fromTime == null) {
            fromTime = LocalDateTime.now().minusDays(30); // 默认查看最近30天
        }

        Map<String, Object> stats = new HashMap<>();

        // 成功发放次数
        long successCount = historyRepository.countSuccessfulIssuancesBetween(fromTime, LocalDateTime.now());
        // 失败发放次数
        long failureCount = historyRepository.countFailedIssuancesBetween(fromTime, LocalDateTime.now());

        long totalCount = successCount + failureCount;

        stats.put("successCount", successCount);
        stats.put("failureCount", failureCount);
        stats.put("totalCount", totalCount);
        stats.put("successRate", totalCount > 0 ? (double) successCount / totalCount : 0.0);
        stats.put("fromTime", fromTime);
        stats.put("toTime", LocalDateTime.now());

        return stats;
    }
}
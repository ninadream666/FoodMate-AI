### 五、CollaborativeAgent 智能体 — 核心实现

#### 5.1 继承架构

```python
class CollaborativeAgent(BaseAgent):
    """第四个智能体，与 ContextAgent/ProfilerAgent/DecisionAgent 同级"""

    def __init__(self):
        super().__init__(
            name="CollaborativeAgent",
            description="协同过滤智能体 - 基于 FoodCF-Encoder + NCF 挖掘用户间行为关联"
        )
        self._encoder = None       # FoodCF-Encoder (懒加载)
        self._ncf_engine = None    # NCF 推理引擎 (懒加载)
```

#### 5.2 处理流程

```python
async def process(self, input_data):
    # 1. 构建用户画像文本 (RLMRec 风格)
    user_profile_text = self._build_user_profile_text(profile_analysis, user_id)

    # 2. 构建餐厅描述文本
    restaurant_texts = [self._build_restaurant_text(r) for r in restaurants]

    # 3. FoodCF-Encoder 编码 (异步, 不阻塞事件循环)
    user_embed = await run_in_executor(self._encoder.encode_user, user_profile_text)
    rest_embeds = await self._get_restaurant_embeddings(restaurant_ids, restaurant_texts)

    # 4. NCF 交互预测
    scores = await run_in_executor(self._ncf_engine.predict, user_embed, rest_embeds)

    # 5. 冷启动权重衰减
    cf_weight = CF_SCORE_WEIGHT  # 默认 0.15
    if is_cold_start:
        cf_weight *= CF_COLD_START_DECAY  # 衰减为 0.05

    return {
        "collaborative_scores": {rid: score for rid, score in zip(restaurant_ids, scores)},
        "cf_weight": cf_weight,
        "encoder_mode": self._encoder.mode,
        "ncf_mode": self._ncf_engine.mode,
    }
```

#### 5.3 冷启动判断

```python
def _is_cold_start(self, profile_analysis):
    """少于 3 次订单视为冷启动"""
    cuisine_freq = profile.get("cuisine_order_frequency", {})
    order_count = sum(cuisine_freq.values())
    return order_count < 3
```

